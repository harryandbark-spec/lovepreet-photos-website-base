{
  "buildCommand": "cd artifacts/lovepreet && pnpm run build",
  "outputDirectory": "artifacts/lovepreet/dist",
  "devCommand": "cd artifacts/lovepreet && pnpm run dev",
  "installCommand": "cd artifacts/lovepreet && pnpm install --no-frozen-lockfile",
  "framework": null,
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
